# Скопируйте на VM: cp .env.vm.example .env
# Замените YOUR_DOMAIN, YOUR_VM_PUBLIC_IP и сгенерируйте SECRET_KEY / POSTGRES_PASSWORD

DEBUG=0
SECRET_KEY=replace-with-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=YOUR_DOMAIN,www.YOUR_DOMAIN,YOUR_VM_PUBLIC_IP,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://YOUR_DOMAIN,http://www.YOUR_DOMAIN,http://YOUR_VM_PUBLIC_IP

POSTGRES_DB=labbooking
POSTGRES_USER=labbooking
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://labbooking:replace-with-strong-password@db:5432/labbooking

REDIS_URL=redis://redis:6379/0

SSO_ENABLED=0
SECURE_SSL_REDIRECT=0
CORS_ALLOWED_ORIGINS=

BOOKING_HORIZON_DAYS=14
BOOKING_CANCEL_HOURS=24
BOOKING_DAY_CLOSES_AT=15:00
BOOKING_DAY_OPENS_AT=22:00
# TIME_ZONE фиксирована в коде: Europe/Moscow

# Email: console для теста, SMTP для пилота
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.university.ru
# EMAIL_PORT=587
# EMAIL_HOST_USER=labbooking@university.ru
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=labbooking@university.ru

# SSO (после пилота)
# SSO_PROVIDER=oidc
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_AUTHORIZATION_URL=
# SSO_TOKEN_URL=
# SSO_USERINFO_URL=
